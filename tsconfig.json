{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "strict": true,               // 强制开启所有严格类型检查
    "noImplicitAny": true,        // 禁止隐式 any
    "strictNullChecks": true,     // 严格空值检查
    "skipLibCheck": true,
    "outDir": "./dist",
    "sourceMap": true
  },
  "include": ["src/**/*"]
}
